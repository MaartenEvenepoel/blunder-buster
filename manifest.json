{
  "manifest_version": 3,
  "name": "Blunder Buster",
  "description": "Analyze your chess.com games with Stockfish engine analysis",
  "version": "1.0.0",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://api.chess.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*"
      ],
      "js": [
        "content/dom-observer.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Blunder Buster"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/stockfish.js",
        "lib/stockfish-nnue-16-single.wasm",
        "lib/chess.js",
        "icons/pieces/*.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
